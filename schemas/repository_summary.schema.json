{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/wzgig/github-hotspots/schemas/repository_summary.schema.json",
  "title": "GitHub Hotspots evidence-grounded editorial response",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "period", "items", "batch_quality"],
  "$defs": {
    "evidenceReferences": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 180
      }
    }
  },
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "4.0"
    },
    "period": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "start", "end"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["daily", "weekly"]
        },
        "start": {
          "type": "string"
        },
        "end": {
          "type": "string"
        }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["status", "rank", "repository", "card", "data_quality"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["ok", "insufficient_data"]
          },
          "rank": {
            "type": "integer"
          },
          "repository": {
            "type": "object",
            "additionalProperties": false,
            "required": ["repository_id", "full_name", "html_url"],
            "properties": {
              "repository_id": {
                "type": ["integer", "null"]
              },
              "full_name": {
                "type": "string"
              },
              "html_url": {
                "type": "string"
              }
            }
          },
          "card": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "project_name",
              "angle",
              "language",
              "stars_total",
              "period_stars_added",
              "period_stars_added_display",
              "forks_total",
              "one_line",
              "highlights",
              "audience",
              "capabilities",
              "core_title",
              "core_summary",
              "prerequisites",
              "limitations",
              "license_label",
              "license_restrictions",
              "readme_sha",
              "content_status",
              "evidence_ids",
              "repository_url"
            ],
            "properties": {
              "project_name": {
                "type": "string"
              },
              "angle": {
                "type": "string",
                "enum": [
                  "positioning",
                  "growth_signal",
                  "tech_stack",
                  "scale",
                  "topics",
                  "activity",
                  "source"
                ]
              },
              "language": {
                "type": ["string", "null"]
              },
              "stars_total": {
                "type": "integer"
              },
              "period_stars_added": {
                "type": ["integer", "null"]
              },
              "period_stars_added_display": {
                "type": "string"
              },
              "forks_total": {
                "type": "integer"
              },
              "one_line": {
                "type": "string",
                "minLength": 1,
                "maxLength": 96
              },
              "highlights": {
                "type": "array",
                "minItems": 3,
                "maxItems": 3,
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 42
                }
              },
              "audience": {
                "type": "string",
                "minLength": 1,
                "maxLength": 72
              },
              "capabilities": {
                "type": "array",
                "minItems": 1,
                "maxItems": 5,
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 42
                }
              },
              "core_title": {
                "type": "string",
                "minLength": 1,
                "maxLength": 24
              },
              "core_summary": {
                "type": "string",
                "minLength": 1,
                "maxLength": 96
              },
              "prerequisites": {
                "type": "string",
                "maxLength": 80
              },
              "limitations": {
                "type": "string",
                "maxLength": 96
              },
              "license_label": {
                "type": "string",
                "maxLength": 40
              },
              "license_restrictions": {
                "type": "string",
                "maxLength": 80
              },
              "readme_sha": {
                "type": ["string", "null"],
                "minLength": 1,
                "maxLength": 128
              },
              "content_status": {
                "type": "string",
                "enum": ["readme_enriched", "metadata_only", "needs_review"]
              },
              "evidence_ids": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "one_line",
                  "highlights",
                  "audience",
                  "capabilities",
                  "core_title",
                  "core_summary",
                  "prerequisites",
                  "limitations",
                  "license_label",
                  "license_restrictions"
                ],
                "properties": {
                  "one_line": {
                    "$ref": "#/$defs/evidenceReferences"
                  },
                  "highlights": {
                    "type": "array",
                    "minItems": 3,
                    "maxItems": 3,
                    "items": {
                      "$ref": "#/$defs/evidenceReferences"
                    }
                  },
                  "audience": {
                    "$ref": "#/$defs/evidenceReferences"
                  },
                  "capabilities": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 5,
                    "items": {
                      "$ref": "#/$defs/evidenceReferences"
                    }
                  },
                  "core_title": {
                    "$ref": "#/$defs/evidenceReferences"
                  },
                  "core_summary": {
                    "$ref": "#/$defs/evidenceReferences"
                  },
                  "prerequisites": {
                    "$ref": "#/$defs/evidenceReferences"
                  },
                  "limitations": {
                    "$ref": "#/$defs/evidenceReferences"
                  },
                  "license_label": {
                    "$ref": "#/$defs/evidenceReferences"
                  },
                  "license_restrictions": {
                    "$ref": "#/$defs/evidenceReferences"
                  }
                }
              },
              "repository_url": {
                "type": "string"
              }
            }
          },
          "data_quality": {
            "type": "object",
            "additionalProperties": false,
            "required": ["delta_source", "delta_is_exact", "warnings"],
            "properties": {
              "delta_source": {
                "type": "string"
              },
              "delta_is_exact": {
                "type": "boolean"
              },
              "warnings": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "batch_quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["forbidden_phrase_hits", "adjacent_angle_repeats", "warnings"],
      "properties": {
        "forbidden_phrase_hits": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "adjacent_angle_repeats": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
