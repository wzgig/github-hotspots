          "summary": {
            "one_line": "正在重写的开源视频编辑器，计划用一套代码覆盖网页、桌面和移动端",
            "highlights": [
              "以 Rust 核心支撑多端编辑器",
              "采用插件优先架构接入第三方扩展",
              "计划提供无界面模式处理自动化渲染"
            ],
            "audience": "适合跟进视频编辑器架构、插件系统和跨端方案的开发者；当前不适合直接依赖新版完成日常剪辑。",
            "capabilities": [
              "计划开放 Editor API",
              "计划接入第三方插件",
              "计划让 AI 智能体通过 MCP 调用",
              "计划执行自动化与批量渲染",
              "计划在编辑器内运行脚本"
            ],
